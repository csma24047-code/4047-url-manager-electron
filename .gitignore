# ==========================================
# 1. すべてを無視
# ==========================================
*

# ==========================================
# 2. フォルダ階層の探索を許可
# ==========================================
!*/

# ==========================================
# 3. 許可するファイル・フォルダ（ホワイトリスト）
# ==========================================
# 設定ファイル関係
!.devcontainer/**
!.vscode/**
!.gitattributes
!.dockerignore
!.gitignore
!readme.md
!docs/**
!components.json
!package.json
!package-lock.json
!electron.vite.config.ts
!**.png

# ソースコード全体を許可（これで src/ 配下はすべてGit管理されます）
!/src/**

# ==========================================
# 4. 例外的に除外するもの（無視リスト）
# ==========================================
# 開発・ビルド時に生成されるフォルダを除外
node_modules/
dist/
out/
database/
assets/