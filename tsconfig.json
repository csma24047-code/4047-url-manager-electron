{
  "compilerOptions": {
    /* ファイル構成：srcから読み込んでdistに出す */
    "rootDir": "./src",
    "outDir": "./dist",

    /* 環境設定：Electronのメインプロセスに合わせる */
    "module": "commonjs",
    "target": "esnext",
    "lib": ["esnext", "dom"], // DOMを追加
    "types": ["node"], // nodeの型を明示

    /* デバッグ用：これがあるとブラウザのデバッグツールで元のTSが見れる */
    "sourceMap": true,

    /* 型チェックの厳しさ（デフォルトを維持しつつ調整） */
    "strict": true,
    "noUncheckedIndexedAccess": true, // 配列のアクセスを厳しくチェック（安全）
    "skipLibCheck": true,
    "esModuleInterop": true // これを追加！ライブラリ読み込みが楽になる
  },
  "include": ["src/**/*"] // srcの中身を全部やるよ、と教えてあげる
}
