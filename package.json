{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "Hello World!!",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "react:build": "vite build",
    "electron:build": "tsc && tsc-alias",
    "build": "npm run react:build && npm run electron:build",
    "start": "npm run build && electron . --no-sandbox --disable-gpu",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\""
  },
  "author": "Jane Doe",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.3.0",
    "electron-store": "^11.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cpx": "^1.5.0",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
