{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "Hello World!!",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "type-check": "tsc",
    "build:react": "vite build",
    "build": "npm run type-check && npm run build:react",
    "launch": "electron . --no-sandbox --disable-gpu",
    "build:launch": "npm run build && npm run launch",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron . --no-sandbox\""
  },
  "author": "Jane Doe",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.3.0",
    "electron-store": "^11.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^9.0.5"
  }
}
