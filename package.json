{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "Hello World!!",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cpx \"src/**/*.{html,css,png,jpg}\" dist",
    "watch": "tsc -w & cpx \"src/**/*.{html,css,png,jpg}\" dist -w",
    "start": "npm run build && electron . --no-sandbox --disable-gpu"
  },
  "author": "Jane Doe",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.3.0",
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cpx": "^1.5.0",
    "typescript": "^6.0.3"
  }
}
